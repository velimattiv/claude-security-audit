# E2E test target configuration.
#
# Pin the upstream target to an exact tag so Juice Shop release drift
# never causes flaky tests. Update the tag and the expected-findings
# fixture in a SINGLE atomic commit — never one without the other.

TARGET_NAME=juice-shop
TARGET_REPO=https://github.com/juice-shop/juice-shop.git
TARGET_TAG=v19.2.1

# Claude Code: the test verifies the host's `claude --version` matches.
# Update this when you upgrade locally + re-run the fixture list to
# catch any behavior drift.
CLAUDE_CODE_VERSION_MIN=0.6.0

# Skill version this fixture list was calibrated against.
# The assertion suite warns if the installed skill's VERSION differs.
SKILL_VERSION_EXPECTED=2.0.2

# Wall-clock cap. Claude Code itself doesn't take a SIGTERM gracefully
# mid-audit, so this is advisory — the script warns at this mark but
# does not kill the process. Hit Ctrl-C if you need to abort.
E2E_TIMEOUT_MIN=90

# Audit invocation args (passed verbatim to `claude -p`).
AUDIT_INVOCATION=/security-audit

# Where to clone the target. Ephemeral — contents wiped on re-run.
TARGET_DIR=/tmp/e2e-target

# Where to stage this run's artifacts (separate from /tmp/audit-targets
# to avoid collision with ad-hoc dogfood runs).
ARTIFACT_DIR=/tmp/e2e-artifacts
