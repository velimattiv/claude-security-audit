# /security-audit — scanner-isolation image
#
# IMPORTANT SCOPE CLARIFICATION: this container isolates the **scanner
# bundle** (semgrep, osv-scanner, gitleaks, trufflehog, trivy, hadolint)
# and the SARIF post-processing tooling. It does NOT run the full skill
# orchestration — Claude Code runs on the host (or wherever you invoke
# it), and sub-agents for deep-dive categories run in whatever runtime
# Claude Code uses.
#
# What this container is good for:
#   - You don't want six scanner binaries (plus their update channels,
#     CVE databases, cached rules) installed globally on your host.
#   - You want reproducible scanner versions: the image pins a known
#     set and the wrapper builds from a checked-in Dockerfile.
#
# What this container is NOT:
#   - A full audit sandbox. Claude Code + sub-agent runtime still sit
#     outside it. Treat it as "sandboxed scanner runtime," not
#     "sandboxed audit."
#
# Usage: scripts/run-audit-in-container.sh
#
# Design:
#   - Install everything as root up front; drop to non-root `audit`
#     for the runtime default.
#   - Target repo bind-mounted read-only; only .claude-audit/ is RW.
#   - --cap-drop=ALL, --read-only rootfs, --security-opt=no-new-privileges
#     applied by the wrapper.

# Base image pinned to a specific digest — the skill's own cat-07
# flags unpinned bases as CWE-829. Update the digest via:
#   docker pull debian:bookworm-slim && docker inspect ...
# or from registry auth token + manifest HEAD (see scripts/README).
FROM debian:bookworm-slim@sha256:f9c6a2fd2ddbc23e336b6257a5245e31f996953ef06cd13a59fa0a1df2d5c252

ARG DEBIAN_FRONTEND=noninteractive

# All root-only setup happens in this first block.
RUN apt-get update && apt-get install -y --no-install-recommends \
      curl \
      wget \
      git \
      jq \
      ca-certificates \
      python3 \
      python3-pip \
      python3-venv \
      tar \
      gzip \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --create-home --shell /bin/bash audit

# Copy skill + scripts in before switching user. The audit user only
# reads these paths at runtime.
COPY scripts/install-scanners.sh /usr/local/bin/install-scanners.sh
COPY scripts/validate-findings.py /opt/security-audit/scripts/validate-findings.py
COPY scripts/verify-unique-findings.py /opt/security-audit/scripts/verify-unique-findings.py
COPY skills/ /opt/security-audit/skills/
RUN chmod +x /usr/local/bin/install-scanners.sh /opt/security-audit/scripts/*.py

# Switch to audit user. All subsequent commands run as non-root.
USER audit
WORKDIR /home/audit

# pip --user installs (semgrep) land in /home/audit/.local/bin.
ENV PATH="/home/audit/.local/bin:/usr/local/bin:${PATH}" \
    PREFIX="/home/audit/.local/bin"

# Install scanners as the audit user. install-scanners.sh resolves
# $PREFIX per call, so writes land in /home/audit/.local/bin (not
# /usr/local/bin — the audit user can't write there).
RUN mkdir -p /home/audit/.local/bin && /usr/local/bin/install-scanners.sh

# Install jsonschema so validate-findings.py runs with the full backend.
# PEP 668 (externally-managed-environment) is enforced on Debian 12+'s
# system Python, so plain `pip3 install --user` fails. We're in a
# container — there's no system Python to protect — so override with
# --break-system-packages, matching install-scanners.sh's fallback for
# semgrep (lines 252-258 of that script).
RUN pip3 install --user --break-system-packages jsonschema==4.22.0

# Mount points — actual mounts come from the wrapper at run time.
#
#   /target                 — target repo (read-only bind mount)
#   /target/.claude-audit   — artifacts (read-write bind mount; host-owned)
#
VOLUME ["/target", "/target/.claude-audit"]

WORKDIR /target

# Default: print preflight, then drop into a shell. The wrapper script
# overrides CMD to invoke specific scanner runs.
CMD ["/bin/bash", "-lc", "echo '=== Scanner isolation container ===' && install-scanners.sh --check && echo && echo 'Container shell — run scanner commands directly (semgrep, osv-scanner, etc.) against /target. Claude Code orchestration runs on the host.'"]
