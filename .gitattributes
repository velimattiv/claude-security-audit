# Normalize line endings across platforms.
* text=auto eol=lf

# Explicit text files (avoid auto-detection edge cases).
*.md        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf
*.py        text eol=lf
*.toml      text eol=lf

# Shell scripts must stay executable.
*.sh        text eol=lf

# Binary file hints (nothing currently, but pre-declare common types
# so future additions don't auto-corrupt).
*.png       binary
*.jpg       binary
*.gif       binary
*.pdf       binary
*.tar.gz    binary
*.zip       binary

# GitHub linguist — don't count test-run writeups or generated fixtures
# against language stats.
docs/test-runs/**    linguist-documentation
tests/fixtures/**    linguist-generated
