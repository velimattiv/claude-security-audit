{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/velimattiv/claude-security-audit/lib/partitions-schema.json",
  "title": "Phase-01 Partition Manifest",
  "description": "Audit partitions with risk scores. Produced by Phase 1, consumed by Phases 2-7.",
  "type": "object",
  "required": [
    "schema_version",
    "skill_version",
    "audit_id",
    "generated_at",
    "partitions",
    "deep_dive_budget"
  ],
  "properties": {
    "schema_version": { "const": 2 },
    "skill_version": { "type": "string" },
    "audit_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "partitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "path",
          "paths_included",
          "paths_excluded",
          "loc",
          "languages",
          "frameworks",
          "risk",
          "depth"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Slug; unique across the manifest."
          },
          "kind": {
            "enum": ["workspace", "service", "language", "codeowners", "dir", "repo"]
          },
          "path": { "type": "string" },
          "paths_included": { "type": "array", "items": { "type": "string" } },
          "paths_excluded": { "type": "array", "items": { "type": "string" } },
          "loc": { "type": "integer", "minimum": 0 },
          "languages": { "type": "array", "items": { "type": "string" } },
          "frameworks": { "type": "array", "items": { "type": "string" } },
          "container_boundary": { "type": "boolean" },
          "trust_zone": { "enum": ["public", "internal", "admin", "dev", "unknown"] },
          "risk": {
            "type": "object",
            "required": ["exposure", "sensitivity", "age", "score", "rationale"],
            "properties": {
              "exposure": { "type": "integer", "minimum": 0, "maximum": 3 },
              "sensitivity": { "type": "integer", "minimum": 0, "maximum": 3 },
              "age": { "type": "integer", "minimum": 0, "maximum": 3 },
              "score": { "type": "integer", "minimum": 0, "maximum": 9 },
              "rationale": { "type": "string", "maxLength": 200 }
            }
          },
          "depth": { "enum": ["full", "inventory-only"] },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "deep_dive_budget": {
      "type": "object",
      "required": ["top_n", "full_depth_count", "inventory_only_count"],
      "properties": {
        "top_n": { "type": "integer", "minimum": 1 },
        "full_depth_count": { "type": "integer", "minimum": 0 },
        "inventory_only_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
